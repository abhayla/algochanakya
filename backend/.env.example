# AlgoChanakya Backend Environment Variables                                                                                                                                                                                                                      
# Application                                                                                                                   
APP_NAME=AlgoChanakya
DEBUG=True
PORT=8000

# PostgreSQL Database
DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/algochanakya_dev

# Redis
REDIS_URL=redis://localhost:6379/1

# JWT Security
JWT_SECRET=generate-a-secure-random-string-min-64-chars
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Frontend URL (used in OAuth callbacks)
FRONTEND_URL=http://localhost:5173

# ── Zerodha (Kite Connect) ────────────────────────────────────────────────────
KITE_API_KEY=your-kite-api-key
KITE_API_SECRET=your-kite-api-secret
KITE_REDIRECT_URL=http://localhost:8000/api/auth/zerodha/callback

# ── AngelOne SmartAPI ─────────────────────────────────────────────────────────
ANGEL_API_KEY=your-angelone-live-api-key
ANGEL_API_SECRET=your-angelone-live-api-secret
ANGEL_HIST_API_KEY=your-angelone-historical-api-key
ANGEL_HIST_API_SECRET=your-angelone-historical-api-secret
ANGEL_TRADE_API_KEY=your-angelone-trade-api-key
ANGEL_TRADE_API_SECRET=your-angelone-trade-api-secret

# Platform AngelOne account (used for platform-default market data)
# These are the credentials of the AngelOne trading account that backs the platform feed
ANGEL_CLIENT_ID=your-angelone-client-id
ANGEL_PIN=your-angelone-trading-pin
ANGEL_TOTP_SECRET=your-angelone-totp-base32-secret

# ── Dhan ──────────────────────────────────────────────────────────────────────
DHAN_CLIENT_ID=your-dhan-client-id
DHAN_ACCESS_TOKEN=your-dhan-static-access-token

# ── Upstox ────────────────────────────────────────────────────────────────────
UPSTOX_API_KEY=your-upstox-api-key
UPSTOX_API_SECRET=your-upstox-api-secret
UPSTOX_REDIRECT_URL=http://localhost:8000/api/auth/upstox/callback

# ── Fyers ─────────────────────────────────────────────────────────────────────
FYERS_APP_ID=your-fyers-app-id
FYERS_SECRET_KEY=your-fyers-secret-key
FYERS_REDIRECT_URL=http://localhost:8000/api/auth/fyers/callback

# ── Paytm Money ───────────────────────────────────────────────────────────────
PAYTM_API_KEY=your-paytm-api-key
PAYTM_API_SECRET=your-paytm-api-secret

# ── Anthropic (AI features) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key