{
  "model": "opusplan",
  "modelProfiles": {
    "opusplan": {
      "planningModel": "claude-opus-4-5-20251101",
      "implementationModel": "claude-sonnet-4-5-20250929"
    }
  },
  "permissions": {
    "allow": [
      "Bash(python -m venv:*)",
      "Bash(dir:*)",
      "Bash(python .claude/hooks/*)"
    ],
    "deny": [],
    "ask": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/validate_workflow_step.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/validate_workflow_step.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/validate_workflow_step.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python .claude/hooks/verify_evidence_artifacts.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/post_test_update.py",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "python .claude/hooks/verify_test_rerun.py",
            "timeout": 300
          },
          {
            "type": "command",
            "command": "python .claude/hooks/post_screenshot_resize.py",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "python .claude/hooks/auto_fix_pattern_scan.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python .claude/hooks/log_workflow.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__playwright__browser_take_screenshot",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/post_screenshot_resize.py",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/log_workflow.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python .claude/hooks/post_skill_learning.py",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/log_workflow.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/log_workflow.py",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
