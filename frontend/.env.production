# AlgoChanakya Frontend Production Environment Variables
# This file is used by Vite when running `npm run build`

# Backend API URL for production
# CRITICAL: Without this, the build defaults to http://localhost:8000 and API calls will fail!
VITE_API_BASE_URL=https://algochanakya.com

# WebSocket URL for live data (prices, AutoPilot status)
# CRITICAL: Without this, WebSocket connects to localhost:8000 and live data won't load!
VITE_WS_URL=algochanakya.com
