# AlgoChanakya Frontend Environment Variables

# Backend API URL
VITE_API_BASE_URL=http://localhost:8000

# Feature flags — opt-in defaults are FALSE for these modules
VITE_ENABLE_AUTOPILOT=false
VITE_ENABLE_AI=false
VITE_ENABLE_WATCHLIST=false
VITE_ENABLE_OFO=false
VITE_ENABLE_BROKER_PAYTM=false
VITE_ENABLE_BROKER_FYERS=false
