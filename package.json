{
  "name": "algochanakya",
  "version": "1.0.0",
  "description": "Options Trading Platform (like Sensibull) - A comprehensive platform for options trading strategies, market analysis, and portfolio management.",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:specs:login": "playwright test tests/e2e/specs/login/",
    "test:specs:dashboard": "playwright test tests/e2e/specs/dashboard/",
    "test:specs:watchlist": "playwright test tests/e2e/specs/watchlist/",
    "test:specs:optionchain": "playwright test tests/e2e/specs/optionchain/",
    "test:specs:strategy": "playwright test tests/e2e/specs/strategy/",
    "test:specs:positions": "playwright test tests/e2e/specs/positions/",
    "test:specs:strategylibrary": "playwright test tests/e2e/specs/strategylibrary/",
    "test:specs:deploy": "playwright test tests/e2e/specs/strategylibrary/strategylibrary.deploy.*.spec.js",
    "test:deploy": "playwright test --grep @deploy",
    "test:specs:navigation": "playwright test tests/e2e/specs/navigation/",
    "test:specs:autopilot": "playwright test tests/e2e/specs/autopilot/",
    "test:main-features": "playwright test tests/e2e/specs/dashboard/ tests/e2e/specs/optionchain/ tests/e2e/specs/ofo/ tests/e2e/specs/strategy/ tests/e2e/specs/strategylibrary/",
    "test:autopilot:fast": "playwright test tests/e2e/specs/autopilot/ --timeout=15000 --workers=4",
    "test:autopilot:phase4": "playwright test tests/e2e/specs/autopilot/autopilot.phase4.spec.js",
    "test:autopilot:phases123": "playwright test tests/e2e/specs/autopilot/autopilot.phases123.spec.js",
    "test:specs:legacy": "playwright test tests/e2e/specs/legacy/",
    "test:happy": "playwright test --grep @happy",
    "test:edge": "playwright test --grep @edge",
    "test:visual": "playwright test --grep @visual",
    "test:api:new": "playwright test --grep @api",
    "test:visual:update": "playwright test --grep @visual --update-snapshots",
    "test:audit": "playwright test --grep @audit",
    "test:a11y": "playwright test --grep @audit",
    "test:consistency": "playwright test tests/e2e/specs/audit/",
    "test:specs:audit": "playwright test tests/e2e/specs/audit/",
    "test:specs:header": "playwright test tests/e2e/specs/header/",
    "test:specs:ofo": "playwright test tests/e2e/specs/ofo/",
    "test:isolated": "playwright test --project=isolated",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "test:allure": "playwright test && npm run allure:generate && npm run allure:open",
    "test:login": "playwright test tests/e2e/specs/legacy/login.spec.js --headed",
    "test:api": "playwright test tests/e2e/specs/legacy/api.spec.js",
    "test:oauth": "playwright test tests/e2e/specs/legacy/oauth-flow.spec.js --headed",
    "test:oauth:auto": "playwright test tests/e2e/specs/integration/oauth-full-flow.spec.js --headed --timeout=120000 --workers=1",
    "test:watchlist": "playwright test tests/e2e/specs/legacy/watchlist.spec.js --headed --timeout=180000",
    "test:verify": "playwright test tests/e2e/specs/legacy/watchlist-manual-verify.spec.js --headed --timeout=300000",
    "test:ws": "playwright test tests/e2e/specs/legacy/websocket-verify.spec.js --headed --timeout=300000",
    "test:strategy": "playwright test tests/e2e/specs/legacy/strategy-builder.spec.js --headed --timeout=300000",
    "test:strategy-verify": "playwright test tests/e2e/specs/legacy/strategy-builder-verify.spec.js --headed --timeout=300000 --workers=1",
    "test:watchlist-fix": "playwright test tests/e2e/specs/legacy/watchlist-fix-verify.spec.js --headed --timeout=300000 --workers=1",
    "test:sb-complete": "playwright test tests/e2e/specs/legacy/strategy-builder-complete.spec.js --headed --timeout=300000 --workers=1",
    "test:iron-condor": "playwright test tests/e2e/specs/legacy/strategy-iron-condor.spec.js --headed --timeout=600000 --workers=1",
    "test:optionchain": "playwright test tests/e2e/specs/legacy/option-chain.spec.js --headed --timeout=300000 --workers=1",
    "test:positions": "playwright test tests/e2e/specs/legacy/positions.spec.js --headed --timeout=300000 --workers=1",
    "test:overflow": "playwright test tests/e2e/specs/legacy/overflow-all-screens.spec.js --headed --timeout=600000 --workers=1",
    "generate:test": "node tests/e2e/scripts/generate-test.js",
    "capture:screenshots": "node tests/e2e/utils/screenshot-capture.js",
    "capture:screenshots:autopilot": "node tests/e2e/utils/screenshot-capture.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abhayla/algochanakya.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/abhayla/algochanakya/issues"
  },
  "homepage": "https://github.com/abhayla/algochanakya#readme",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.57.0",
    "allure-playwright": "^3.4.3"
  }
}
